generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HiveStatus {
  OK
  OBSERVE
  ACTION
  UNKNOWN
  INACTIVE
}

enum QueenStatus {
  ACTIVE
  INTRODUCED
  ACCEPTED
  REJECTED
  REPLACED
  MISSING
  WATCH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  apiaries    Apiary[]
  hives       Hive[]
  queens      Queen[]
  inspections Inspection[]
  feedings    Feeding[]
  treatments  Treatment[]
  tasks       Task[]
  notes       Note[]
  photos      Photo[]
  syncEvents  SyncEvent[]
  auditLogs   AuditLog[]

  @@index([email])
}

model Apiary {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  location    String?
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hives Hive[]

  @@index([ownerId])
  @@index([ownerId, deletedAt])
}

model Hive {
  id              String     @id @default(uuid())
  ownerId         String
  apiaryId        String
  name            String
  hiveType        String?
  status          HiveStatus @default(UNKNOWN)
  strength        Int?
  lastInspectionAt DateTime?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  apiary      Apiary       @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  queens      Queen[]
  inspections Inspection[]
  feedings    Feeding[]
  treatments  Treatment[]
  tasks       Task[]
  notesList   Note[]
  photos      Photo[]

  @@index([ownerId])
  @@index([apiaryId])
  @@index([ownerId, status])
  @@index([ownerId, deletedAt])
}

model Queen {
  id             String      @id @default(uuid())
  ownerId        String
  hiveId         String?
  name           String?
  line           String?
  race           String?
  year           Int?
  markingColor   String?
  origin         String?
  introducedAt   DateTime?
  acceptedAt     DateTime?
  status         QueenStatus @default(WATCH)
  layingRating   Int?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive? @relation(fields: [hiveId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, deletedAt])
}

model Inspection {
  id           String   @id @default(uuid())
  ownerId      String
  hiveId       String
  inspectedAt  DateTime @default(now())
  weather      String?
  temperature  Float?
  mood         String?
  strength     Int?
  queenSeen    Boolean?
  eggs         Boolean?
  openBrood    Boolean?
  cappedBrood  Boolean?
  foodLevel    String?
  pollenLevel  String?
  queenCells   Int?
  diseases     String?
  varroa        String?
  framesAdded   Int?
  framesRemoved Int?
  note         String?
  details      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, inspectedAt])
  @@index([ownerId, deletedAt])
}

model Feeding {
  id        String   @id @default(uuid())
  ownerId   String
  hiveId    String
  fedAt     DateTime @default(now())
  type      String
  amount    Float?
  unit      String?
  purpose   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, fedAt])
  @@index([ownerId, deletedAt])
}

model Treatment {
  id        String   @id @default(uuid())
  ownerId   String
  hiveId    String
  treatedAt DateTime @default(now())
  product   String
  dose      String?
  method    String?
  stage     String?
  nextCheckAt DateTime?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, treatedAt])
  @@index([ownerId, deletedAt])
}

model Task {
  id          String     @id @default(uuid())
  ownerId     String
  hiveId      String?
  title       String
  description String?
  dueAt       DateTime?
  priority    Priority   @default(NORMAL)
  status      TaskStatus @default(TODO)
  source      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive? @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, status])
  @@index([ownerId, dueAt])
  @@index([ownerId, deletedAt])
}

model Note {
  id        String   @id @default(uuid())
  ownerId   String
  hiveId    String?
  title     String?
  body      String
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive? @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, deletedAt])
}

model Photo {
  id        String   @id @default(uuid())
  ownerId   String
  hiveId    String?
  url       String
  caption   String?
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hive  Hive? @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([hiveId])
  @@index([ownerId, deletedAt])
}

model SyncEvent {
  id        String   @id @default(uuid())
  ownerId   String
  clientId  String?
  type      String
  entity    String
  entityId  String?
  payload   Json?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  ownerId   String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([createdAt])
}
