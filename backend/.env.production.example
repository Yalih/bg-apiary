NODE_ENV=production
PORT=3000
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/bg_apiary?schema=public"
JWT_ACCESS_SECRET="CHANGE_THIS_TO_LONG_RANDOM_ACCESS_SECRET"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_LONG_RANDOM_REFRESH_SECRET"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
CORS_ORIGIN="https://bgapiary.pro"
LOG_LEVEL="info"
PGADMIN_DEFAULT_EMAIL="admin@bgapiary.pro"
PGADMIN_DEFAULT_PASSWORD="CHANGE_THIS_PGADMIN_PASSWORD"
