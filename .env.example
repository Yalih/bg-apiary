# BG Apiary 1.0 Production
NODE_ENV=production
APP_VERSION=1.0.0
APP_URL=http://localhost

# Backend
API_PORT=4000
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost,https://bgapiary.pro

# PostgreSQL
POSTGRES_DB=bg_apiary
POSTGRES_USER=bg_apiary
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://bg_apiary:change-this-db-password@postgres:5432/bg_apiary?schema=public

# pgAdmin optional
PGADMIN_DEFAULT_EMAIL=admin@bgapiary.local
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password
